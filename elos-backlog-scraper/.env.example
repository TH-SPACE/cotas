# Banco de dados (MariaDB/MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cotas

# Credenciais de login no site Elos (intranet) -- fallback: normalmente vem da
# tabela elos_credenciais (cadastrada pela pagina da calculadora), so usa isso
# aqui se a tabela ainda estiver vazia.
ELOS_USER=
ELOS_PASSWORD=

# Mesma chave usada em calculadora_cotas/.env -- necessaria pra descriptografar
# a senha que vem de elos_credenciais (ver cryptoUtil.js). Sem isso, ou com uma
# chave diferente da que criptografou, a leitura da senha falha.
ELOS_CRED_ENCRYPTION_KEY=

# Opcionais
# ELOS_URL=http://10.31.36.30/elos
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# HEADLESS=false
# TIPO_SERVICO=instalacoes  # ou "reparos" -- a tela ja abre em Instalacoes por padrao
# BACKLOG_TABLE=backlog_elos              # usada quando TIPO_SERVICO=reparos
# INSTALACOES_TABLE=backlog_instalacoes   # usada quando TIPO_SERVICO=instalacoes (padrao)
# REGIOES_VALIDAS=CENTRO OESTE,NORTE
# MIN_LINHAS=1000
# BATCH_SIZE=500
