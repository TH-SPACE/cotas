<%- include('partials/head') %>

<section class="panel">
  <div class="panel-header panel-header-row">
    <div>
      <h2 title="Todos os ajustes usados nos cálculos das 4 seções (Instalações, Serviços, ME e Reparos), reunidos em uma única página">
        <svg class="title-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.65 1.65 0 0 0-1.8-.3 1.65 1.65 0 0 0-1 1.5V21a2 2 0 0 1-4 0v-.1A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.65 1.65 0 0 0 .3-1.8 1.65 1.65 0 0 0-1.5-1H3a2 2 0 0 1 0-4h.1A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.65 1.65 0 0 0 1.8.3H9a1.65 1.65 0 0 0 1-1.5V3a2 2 0 0 1 4 0v.1a1.65 1.65 0 0 0 1 1.5 1.65 1.65 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.65 1.65 0 0 0-.3 1.8V9a1.65 1.65 0 0 0 1.5 1H21a2 2 0 0 1 0 4h-.1a1.65 1.65 0 0 0-1.5 1z"/></svg>
        Configurações
      </h2>
      <p class="hint">
        Upload manual do backlog, Previsto/Janelas/PU/Carga e Tempos por bucket em tabelas únicas (coluna por seção) + PU por Specification Product de cada seção.
      </p>
    </div>
    <div class="panel-header-actions">
      <a href="<%= linkVoltar %>" class="icon-btn" title="Voltar para a página principal">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
    </div>
  </div>
</section>

<section class="panel config-page-panel" id="config-upload">
  <div class="modal-header">
    <h3 title="Envia manualmente o export diário do ELOS para as tabelas backlog_instalacoes e backlog_elos">Upload manual de backlog</h3>
  </div>

  <% if (instalacoesUpload === 'ok') { %>
    <p class="alert alert-ok" style="margin: 1.25rem 1.25rem 0;">Arquivo de instalações importado: <strong><%= instalacoesUploadLinhas %></strong> linhas gravadas em <code>backlog_instalacoes</code>.</p>
  <% } else if (instalacoesUpload === 'erro') { %>
    <p class="alert alert-erro" style="margin: 1.25rem 1.25rem 0;">Falha ao importar instalações: <%= instalacoesUploadErro %></p>
  <% } %>
  <% if (reparosUpload === 'ok') { %>
    <p class="alert alert-ok" style="margin: 1.25rem 1.25rem 0;">Arquivo de reparos importado: <strong><%= reparosUploadLinhas %></strong> linhas gravadas em <code>backlog_elos</code>.</p>
  <% } else if (reparosUpload === 'erro') { %>
    <p class="alert alert-erro" style="margin: 1.25rem 1.25rem 0;">Falha ao importar reparos: <%= reparosUploadErro %></p>
  <% } %>

  <div class="upload-compact-grid">
    <form class="cota-upload-item" method="post" action="/instalacoes/upload" enctype="multipart/form-data">
      <div class="cota-upload-head">
        <span class="cota-upload-tipo">Instalações / ME / Serviços</span>
        <span class="cota-upload-data" title="Última carga registrada"><%= dataCargaInstalacoes %></span>
      </div>
      <div class="cota-upload-row">
        <input type="file" name="arquivo" accept=".csv,.txt" required aria-label="CSV de Instalações / ME / Serviços" />
        <button type="submit" title="Envia e substitui os dados de backlog_instalacoes">Enviar</button>
      </div>
      <p class="cota-upload-hint">CSV <code>BackLogDiario_*.csv</code> — substitui <code>backlog_instalacoes</code>.</p>
    </form>

    <form class="cota-upload-item" method="post" action="/reparos/upload" enctype="multipart/form-data">
      <div class="cota-upload-head">
        <span class="cota-upload-tipo">Reparos</span>
        <span class="cota-upload-data" title="Última carga registrada"><%= dataCargaReparo %></span>
      </div>
      <div class="cota-upload-row">
        <input type="file" name="arquivo" accept=".csv,.txt" required aria-label="CSV de Reparos" />
        <button type="submit" title="Envia e substitui os dados de backlog_elos">Enviar</button>
      </div>
      <p class="cota-upload-hint cota-upload-hint-warn">⚠ Substitui <code>backlog_elos</code> — tabela compartilhada com outro sistema: arquivo errado apaga dados que não são deste app.</p>
    </form>
  </div>
</section>

<section class="panel config-page-panel" id="config-previsto">
  <div class="modal-header">
    <h3 title="Previsto de resolução, janelas de horário, Meta de PU por técnico e Carga (usada na coluna Sugestão) de cada seção">Previsto, Janelas, PU e Carga</h3>
  </div>

  <form method="post" action="/config/geral" class="modal-section">
    <%- include('partials/hidden-config-estado', { exceto: [] }) %>
    <div class="modal-body">
      <table class="tempo-table">
        <thead>
          <tr>
            <th>Configuração</th>
            <th class="num">Instalação</th>
            <th class="num">Serviço</th>
            <th class="num">ME</th>
            <th class="num">Reparos</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Previsto de resolução (%)</td>
            <td class="num"><input type="number" id="percentualInstalacao" name="percentualInstalacao" min="0" max="100" step="1" value="<%= percentualInstalacao %>" title="Percentual do backlog de Instalações considerado resolvível" /></td>
            <td class="num"><input type="number" id="percentualServico" name="percentualServico" min="0" max="100" step="1" value="<%= percentualServico %>" title="Percentual do backlog de Serviços considerado resolvível" /></td>
            <td class="num"><input type="number" id="percentualMe" name="percentualMe" min="0" max="100" step="1" value="<%= percentualMe %>" title="Percentual do backlog de ME considerado resolvível" /></td>
            <td class="num"><input type="number" id="percentual" name="percentual" min="0" max="100" step="1" value="<%= percentual %>" title="Percentual do backlog de Reparos considerado resolvível" /></td>
          </tr>
          <tr>
            <td>08:30 - 10:30 (%)</td>
            <td class="num"><input type="number" id="percentualJanela1Instalacao" name="percentualJanela1Instalacao" min="0" max="100" step="1" value="<%= percentualJanela1Instalacao %>" title="Instalação: janela 08:30 - 10:30" /></td>
            <td class="num"><input type="number" id="percentualJanela1Servico" name="percentualJanela1Servico" min="0" max="100" step="1" value="<%= percentualJanela1Servico %>" title="Serviço: janela 08:30 - 10:30" /></td>
            <td class="num"><input type="number" id="percentualJanela1Me" name="percentualJanela1Me" min="0" max="100" step="1" value="<%= percentualJanela1Me %>" title="ME: janela 08:30 - 10:30" /></td>
            <td class="num">
              <input type="number" id="percentualJanela" name="percentualJanela" min="0" max="100" step="1" value="<%= percentualJanela %>" title="Reparos: janela 08:30 - 12:30" />
              <span class="tempo-table-subcaption">08:30-12:30</span>
            </td>
          </tr>
          <tr>
            <td>10:30 - 12:30 (%)</td>
            <td class="num"><input type="number" id="percentualJanela2Instalacao" name="percentualJanela2Instalacao" min="0" max="100" step="1" value="<%= percentualJanela2Instalacao %>" title="Instalação: janela 10:30 - 12:30" /></td>
            <td class="num"><input type="number" id="percentualJanela2Servico" name="percentualJanela2Servico" min="0" max="100" step="1" value="<%= percentualJanela2Servico %>" title="Serviço: janela 10:30 - 12:30" /></td>
            <td class="num"><input type="number" id="percentualJanela2Me" name="percentualJanela2Me" min="0" max="100" step="1" value="<%= percentualJanela2Me %>" title="ME: janela 10:30 - 12:30" /></td>
            <td class="num">
              <input type="number" id="percentualJanelaTarde" min="0" max="100" step="1" value="<%= 100 - percentualJanela %>" title="Reparos: janela 12:30 - 18:00 — calculada (100% menos a janela 08:30-12:30)" readonly tabindex="-1" />
              <span class="tempo-table-subcaption">12:30-18:00, calculada</span>
            </td>
          </tr>
          <tr>
            <td>14:00 - 16:00 (%)</td>
            <td class="num"><input type="number" id="percentualJanela3Instalacao" name="percentualJanela3Instalacao" min="0" max="100" step="1" value="<%= percentualJanela3Instalacao %>" title="Instalação: janela 14:00 - 16:00" /></td>
            <td class="num"><input type="number" id="percentualJanela3Servico" name="percentualJanela3Servico" min="0" max="100" step="1" value="<%= percentualJanela3Servico %>" title="Serviço: janela 14:00 - 16:00" /></td>
            <td class="num"><input type="number" id="percentualJanela3Me" name="percentualJanela3Me" min="0" max="100" step="1" value="<%= percentualJanela3Me %>" title="ME: janela 14:00 - 16:00" /></td>
            <td class="num celula-napplicavel" title="Reparos só tem 2 janelas (08:30-12:30 e 12:30-18:00)">—</td>
          </tr>
          <tr>
            <td>16:00 - 18:00 (%, calculada)</td>
            <td class="num"><input type="number" id="percentualJanela4Instalacao" min="0" max="100" step="1" value="<%= Math.max(0, 100 - percentualJanela1Instalacao - percentualJanela2Instalacao - percentualJanela3Instalacao) %>" title="Instalação: janela 16:00 - 18:00 — calculada" readonly tabindex="-1" /></td>
            <td class="num"><input type="number" id="percentualJanela4Servico" min="0" max="100" step="1" value="<%= Math.max(0, 100 - percentualJanela1Servico - percentualJanela2Servico - percentualJanela3Servico) %>" title="Serviço: janela 16:00 - 18:00 — calculada" readonly tabindex="-1" /></td>
            <td class="num"><input type="number" id="percentualJanela4Me" min="0" max="100" step="1" value="<%= Math.max(0, 100 - percentualJanela1Me - percentualJanela2Me - percentualJanela3Me) %>" title="ME: janela 16:00 - 18:00 — calculada" readonly tabindex="-1" /></td>
            <td class="num celula-napplicavel" title="Reparos só tem 2 janelas (08:30-12:30 e 12:30-18:00)">—</td>
          </tr>
          <tr>
            <td>Meta de PU por técnico</td>
            <td class="num"><input type="number" id="metaPuTecnicoInstalacao" name="metaPuTecnicoInstalacao" min="0.1" step="0.1" value="<%= metaPuTecnicoInstalacao %>" title="PU que 1 técnico de Instalações entrega" /></td>
            <td class="num"><input type="number" id="metaPuTecnicoServico" name="metaPuTecnicoServico" min="0.1" step="0.1" value="<%= metaPuTecnicoServico %>" title="PU que 1 técnico de Serviços entrega" /></td>
            <td class="num"><input type="number" id="metaPuTecnicoMe" name="metaPuTecnicoMe" min="0.1" step="0.1" value="<%= metaPuTecnicoMe %>" title="PU que 1 técnico de ME entrega" /></td>
            <td class="num"><input type="number" id="metaPuTecnico" name="metaPuTecnico" min="0.1" step="0.1" value="<%= metaPuTecnico %>" title="PU que 1 técnico de Reparos entrega" /></td>
          </tr>
          <tr>
            <td>Carga (coluna Sugestão)</td>
            <td class="num"><input type="number" id="cargaInstalacao" name="cargaInstalacao" min="0" step="0.01" value="<%= cargaInstalacao %>" title="Carga a distribuir entre os buckets de Instalação" /></td>
            <td class="num"><input type="number" id="cargaServico" name="cargaServico" min="0" step="0.01" value="<%= cargaServico %>" title="Carga a distribuir entre os buckets de Serviço" /></td>
            <td class="num"><input type="number" id="cargaMe" name="cargaMe" min="0" step="0.01" value="<%= cargaMe %>" title="Carga a distribuir entre os buckets de ME" /></td>
            <td class="num"><input type="number" id="cargaReparo" name="cargaReparo" min="0" step="0.01" value="<%= cargaReparo %>" title="Carga a distribuir entre os buckets de Reparos" /></td>
          </tr>
          <tr>
            <td>PU do reparo (peso fixo)</td>
            <td class="num celula-napplicavel" title="Instalação usa PU por Specification Product (tabela própria abaixo)">—</td>
            <td class="num celula-napplicavel" title="Serviço usa PU por Specification Product (tabela própria abaixo)">—</td>
            <td class="num celula-napplicavel" title="ME usa PU por Specification Product (tabela própria abaixo)">—</td>
            <td class="num"><input type="number" id="puReparo" name="puReparo" min="0" step="0.01" value="<%= puReparo %>" title="PU gerado por cada reparo sugerido" /></td>
          </tr>
        </tbody>
      </table>
      <p class="hint">Instalação/Serviço/ME usam as 4 janelas do rótulo da linha (somam 100% — as 3 primeiras editáveis, a última calculada). Reparos tem horários diferentes e só 2 janelas (08:30-12:30 e 12:30-18:00, indicadas embaixo do campo, também somando 100% entre si) — por isso não usa as linhas de 14:00-16:00 e 16:00-18:00.</p>
      <p class="hint">Sugestão (por bucket, em cada seção) = (Previsto do bucket ÷ Previsto total da seção) × Carga. Ordens, Cotas(min), PU e Técnicos são todos calculados a partir da Sugestão — Previsto é só a referência usada para ratear a Carga.</p>
    </div>

    <div class="modal-footer">
      <button type="submit" title="Grava estes valores em configuracoes_gerais">Aplicar</button>
    </div>
  </form>
</section>

<section class="panel config-page-panel" id="config-tempos">
  <div class="modal-header">
    <h3 title="Tempo médio (minutos) de cada tipo de atendimento em cada bucket">Tempos por bucket (min)</h3>
  </div>

  <form method="post" action="/config/tempo-bucket" class="modal-section">
    <%- include('partials/hidden-config-estado', { exceto: [] }) %>
    <div class="modal-body">
      <p class="hint">
        Uma linha por bucket (tabela <code>depara_tempo_bucket</code>) — Instalação, Serviço, ME e Reparo são colunas da
        mesma linha, não tabelas separadas, então ficam juntas aqui também.
      </p>
      <table class="tempo-table">
        <thead>
          <tr>
            <th title="Empresa aliada dona do bucket">Aliada</th>
            <th title="Nome do bucket em depara_tempo_bucket">Bucket</th>
            <th class="num" title="Minutos que uma instalação leva neste bucket">Instalação (min)</th>
            <th class="num" title="Minutos que um serviço leva neste bucket">Serviço (min)</th>
            <th class="num" title="Minutos que uma ME leva neste bucket">ME (min)</th>
            <th class="num" title="Minutos que um reparo leva neste bucket">Reparo (min)</th>
          </tr>
        </thead>
        <tbody>
          <% let aliadaTempoBucketAtual = null; %>
          <% temposBucket.forEach(t => { %>
            <% const novaAliadaTempoBucket = t.aliada !== aliadaTempoBucketAtual; aliadaTempoBucketAtual = t.aliada; %>
            <tr class="<%= novaAliadaTempoBucket ? 'group-start' : '' %>">
              <td><span class="aliada-badge aliada-color-<%= aliadaCoresTemposBucket[t.aliada] %>"><%= t.aliada %></span></td>
              <td class="celula-truncada" title="<%= t.bucket %>"><%= t.bucket %></td>
              <td class="num">
                <input type="hidden" name="bucket[]" value="<%= t.bucket %>" />
                <input type="number" name="instalacao[]" min="0" step="1" value="<%= t.instalacao %>" aria-label="Tempo de instalação (min) para <%= t.bucket %>" title="Minutos de uma instalação em <%= t.bucket %>" />
              </td>
              <td class="num">
                <input type="number" name="servico[]" min="0" step="1" value="<%= t.servico %>" aria-label="Tempo de serviço (min) para <%= t.bucket %>" title="Minutos de um serviço em <%= t.bucket %>" />
              </td>
              <td class="num">
                <input type="number" name="alteracao[]" min="0" step="1" value="<%= t.alteracao %>" aria-label="Tempo de ME (min) para <%= t.bucket %>" title="Minutos de uma ME em <%= t.bucket %>" />
              </td>
              <td class="num">
                <input type="number" name="reparo[]" min="0" step="1" value="<%= t.reparo %>" aria-label="Tempo de reparo (min) para <%= t.bucket %>" title="Minutos de um reparo em <%= t.bucket %>" />
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="modal-footer">
      <button type="submit" title="Grava estes tempos em depara_tempo_bucket">Salvar tempos</button>
    </div>
  </form>
</section>

<section class="panel config-page-panel" id="config-pu-produto">
  <div class="modal-header">
    <h3 title="Peso de PU de cada Specification Product, por seção — Instalação, Serviço e ME têm listas de produtos próprias (Reparos usa PU fixo, configurado na tabela de Previsto/Janelas/PU/Carga)">PU por Specification Product</h3>
  </div>

  <form method="post" action="/config/pu-produto-todos" class="modal-section">
    <%- include('partials/hidden-config-estado', { exceto: [] }) %>

    <div class="modal-body">
      <p class="hint">
        Instalação, Serviço e ME têm produtos diferentes (tabelas <code>depara_pu_produto</code>,
        <code>depara_pu_produto_servico</code> e <code>depara_pu_produto_me</code>) — por isso não dá pra juntar linha a
        linha como em Tempos por bucket, mas ficam todas na mesma tabela, agrupadas por seção.
      </p>
      <table class="tempo-table">
        <thead>
          <tr>
            <th title="A qual seção este produto pertence">Seção</th>
            <th title="Valor da coluna SPECIFICATION_PRODUCT no CSV do ELOS">Specification Product</th>
            <th class="num" title="Quantas PU cada ocorrência deste produto representa">PU</th>
          </tr>
        </thead>
        <tbody>
          <% puProdutos.forEach((p, i) => { %>
            <tr class="<%= (i === 0 ? 'group-start ' : '') + (p.pu == 0 ? 'linha-alerta' : '') %>">
              <td>Instalação</td>
              <td>
                <%= p.produto %>
                <% if (p.pu == 0) { %>
                  <span class="badge-alerta" title="Este produto ainda não tem PU configurado — está contando 0 no cálculo">sem PU</span>
                <% } %>
              </td>
              <td class="num">
                <input type="hidden" name="produtoInstalacao[]" value="<%= p.produto %>" />
                <input type="number" name="puInstalacao[]" min="0" step="0.01" value="<%= p.pu %>" aria-label="PU para <%= p.produto %> (Instalação)" title="PU de uma instalação do produto <%= p.produto %>" />
              </td>
            </tr>
          <% }) %>
          <% puProdutosServicos.forEach((p, i) => { %>
            <tr class="<%= (i === 0 ? 'group-start ' : '') + (p.pu == 0 ? 'linha-alerta' : '') %>">
              <td>Serviço</td>
              <td>
                <%= p.produto %>
                <% if (p.pu == 0) { %>
                  <span class="badge-alerta" title="Este produto ainda não tem PU configurado — está contando 0 no cálculo">sem PU</span>
                <% } %>
              </td>
              <td class="num">
                <input type="hidden" name="produtoServico[]" value="<%= p.produto %>" />
                <input type="number" name="puServico[]" min="0" step="0.01" value="<%= p.pu %>" aria-label="PU para <%= p.produto %> (Serviço)" title="PU de um serviço do produto <%= p.produto %>" />
              </td>
            </tr>
          <% }) %>
          <% puProdutosMe.forEach((p, i) => { %>
            <tr class="<%= (i === 0 ? 'group-start ' : '') + (p.pu == 0 ? 'linha-alerta' : '') %>">
              <td>ME</td>
              <td>
                <%= p.produto %>
                <% if (p.pu == 0) { %>
                  <span class="badge-alerta" title="Este produto ainda não tem PU configurado — está contando 0 no cálculo">sem PU</span>
                <% } %>
              </td>
              <td class="num">
                <input type="hidden" name="produtoMe[]" value="<%= p.produto %>" />
                <input type="number" name="puMe[]" min="0" step="0.01" value="<%= p.pu %>" aria-label="PU para <%= p.produto %> (ME)" title="PU de uma ME do produto <%= p.produto %>" />
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p class="hint">Produtos novos aparecem aqui automaticamente ao subir um CSV (com PU=0 até serem configurados).</p>
    </div>

    <div class="modal-footer">
      <button type="submit" title="Grava estes pesos em depara_pu_produto, depara_pu_produto_servico e depara_pu_produto_me">Salvar PU</button>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
