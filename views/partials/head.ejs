<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Calculadora de Cotas - GO' %></title>
  <link rel="icon" type="image/svg+xml" href="/img_vivo/vivo-velocimetro-brilho-rosa-centro-320x320.svg" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="topbar">
    <h1 title="Estima quantos técnicos são necessários para atender o backlog de reparos de Goiânia">
      <a href="/" class="topbar-link">
        <img src="/img_vivo/vivo-velocimetro-brilho-rosa-centro-320x320.svg" alt="" class="topbar-logo" />
        Calculadora de Cotas <span class="badge" title="Cluster GOIANIA">GO</span>
      </a>
    </h1>
    <% // Navbar = só as 3 páginas do sistema (Início / Resumo COTAS / Cotas
       // Planejadas). Os atalhos das seções (Instalações/Serviços/ME/Reparos) e o
       // link de Configurações saíram daqui e foram pra barra lateral da página
       // inicial (ver index.ejs .home-sidebar). `linkVoltar` preserva os filtros ao
       // voltar pra index a partir das outras páginas. %>
    <nav class="topbar-nav" aria-label="Navegação principal">
      <a href="<%= typeof linkVoltar !== 'undefined' ? linkVoltar : '/' %>" class="topbar-nav-item" title="Página inicial — backlog de Instalações, Serviços, ME e Reparos">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/></svg>
        <span>Início</span>
      </a>
      <a href="<%= typeof linkResumoCotas !== 'undefined' ? linkResumoCotas : '/resumo-cotas' %>" class="topbar-nav-item" title="Ver resumo consolidado de COTAS(min) de Instalação, ME, Serviços e Reparos, um por bucket">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span>Resumo COTAS</span>
      </a>
      <a href="<%= typeof linkCotasPlanejadas !== 'undefined' ? linkCotasPlanejadas : '/cotas-planejadas' %>" class="topbar-nav-item" title="Cotas planejadas por bucket em cada janela, comparadas com as cotas do dia (D0) do Elos">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M8 4H6a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-2"/><path d="m9 14 2 2 4-4"/></svg>
        <span>Cotas Planejadas</span>
      </a>
    </nav>
    <button type="button" class="icon-btn" id="config-elos-open-btn" aria-haspopup="dialog" aria-controls="config-elos-modal" title="Credenciais de login da raspagem automática do Elos">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="15" r="4"/><path d="M10.5 12.5 20 3M17 6l3 3M14 9l2 2"/></svg>
    </button>
  </header>
  <dialog id="config-elos-modal" class="config-modal">
    <div class="modal-header">
      <h3 title="Login usado pela raspagem automática (elos-backlog-scraper) que baixa o backlog de Instalações do Elos a cada 10-25 min">Credenciais do Elos</h3>
      <button type="button" class="icon-btn" id="config-elos-close-btn" aria-label="Fechar" title="Fechar">&times;</button>
    </div>

    <form method="post" action="/config/elos-credenciais" class="modal-section" data-loading="Salvando credenciais…">
      <div class="modal-body">
        <p class="hint">
          Login usado pela raspagem automática do backlog de Instalações. Troque aqui quando quem
          costuma cuidar disso sair (férias, etc.) e outra pessoa precisar usar seu próprio usuário.
        </p>
        <p class="hint" id="raspagem-status-box">
          <span id="raspagem-status-texto">Carregando status da raspagem...</span>
        </p>
        <div class="raspagem-screenshots" id="raspagem-screenshots">
          <img data-nome="1-tela-principal.jpg" alt="Tela principal" title="Clique para ampliar: Tela principal" role="button" tabindex="0" />
          <img data-nome="2-tela-dashboard.jpg" alt="Dashboard" title="Clique para ampliar: Abrindo Dashboards" role="button" tabindex="0" />
          <img data-nome="3-click-menu-1.jpg" alt="Menu Backlog" title="Clique para ampliar: Menu Backlog" role="button" tabindex="0" />
          <img data-nome="4-click-menu-2.jpg" alt="Submenu Backlog" title="Clique para ampliar: Submenu Backlog" role="button" tabindex="0" />
          <img data-nome="5-dashboard-carregado.jpg" alt="Backlog carregado" title="Clique para ampliar: Backlog carregado" role="button" tabindex="0" />
          <img data-nome="5-erro-dashboard-nao-carregou.jpg" alt="Erro" title="Clique para ampliar: Erro ao carregar o dashboard" role="button" tabindex="0" />
        </div>
        <div class="field-row">
          <span class="hint" style="margin: 0;">Não quer esperar o próximo intervalo automático?</span>
          <button type="button" class="btn-secundario" id="raspagem-executar-agora-btn" title="Solicita que a raspagem rode agora, sem esperar o intervalo normal (10 a 25 min)">Executar agora</button>
        </div>
        <div class="field-row">
          <label for="elos-usuario-input">Usuário Elos</label>
          <input
            type="text"
            id="elos-usuario-input"
            name="elosUsuario"
            autocomplete="off"
            required
            value="<%= (typeof elosCredenciais !== 'undefined' && elosCredenciais) ? elosCredenciais.usuario : '' %>"
          />
        </div>
        <div class="field-row">
          <label for="elos-senha-input">Senha Elos</label>
          <input
            type="password"
            id="elos-senha-input"
            name="elosSenha"
            autocomplete="off"
            placeholder="<%= (typeof elosCredenciais !== 'undefined' && elosCredenciais) ? 'deixe em branco para manter a atual' : '' %>"
          />
        </div>
        <% if (typeof elosCredenciais !== 'undefined' && elosCredenciais) { %>
          <p class="hint">Atualizado em <strong><%= elosCredenciais.atualizadoEm %></strong></p>
        <% } %>
      </div>
      <div class="modal-footer">
        <button type="submit" title="Salva as credenciais do Elos">Salvar</button>
      </div>
    </form>
  </dialog>
  <dialog id="raspagem-screenshot-lightbox" class="lightbox-modal">
    <div class="lightbox-modal-header">
      <button type="button" class="icon-btn" id="raspagem-screenshot-lightbox-close" aria-label="Fechar" title="Fechar">&times;</button>
    </div>
    <img id="raspagem-screenshot-lightbox-img" alt="Screenshot ampliado" />
  </dialog>
  <main class="container">
