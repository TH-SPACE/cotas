<% if (!_exceto.includes('percentualServico')) { %><input type="hidden" name="percentualServico" value="<%= percentualServico %>" /><% } %>
<% if (!_exceto.includes('percentualJanela1Servico')) { %><input type="hidden" name="percentualJanela1Servico" value="<%= percentualJanela1Servico %>" /><% } %>
