  <% statusInstalacaoSelecionados.forEach(v => { %><input type="hidden" name="statusInstalacao" value="<%= v %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('statusReasonInstalacao')) { %>
  <% statusReasonInstalacaoSelecionados.forEach(v => { %><input type="hidden" name="statusReasonInstalacao" value="<%= v %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('tecnologiaAcesso')) { %>
  <% tecnologiaAcessoSelecionadas.forEach(v => { %><input type="hidden" name="tecnologiaAcesso" value="<%= v %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('statusServico')) { %>
  <% statusServicoSelecionados.forEach(v => { %><input type="hidden" name="statusServico" value="<%= v %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('statusReasonServico')) { %>
