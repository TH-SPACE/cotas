<% } %>
<% if (!_exceto.includes('tecnologiaAcessoMe')) { %>
  <% tecnologiaAcessoMeSelecionadas.forEach(v => { %><input type="hidden" name="tecnologiaAcessoMe" value="<%= v %>" /><% }) %>
<% } %>
