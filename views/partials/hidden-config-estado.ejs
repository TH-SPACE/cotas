<%
/*
  Reaproveitado por todo formulário que recarrega "/": carrega os FILTROS atuais
  (status/status reason/tecnologia dos 4 painéis) como campos ocultos, exceto os
  campos que o próprio formulário já expõe como input visível (passados em
  `exceto`, um array de nomes) — evita o form "resetar" os filtros dos outros
  painéis quando só um é submetido. Previsto/Janelas/Meta de PU/Carga NÃO entram
  mais aqui -- persistem em configuracoes_gerais (ver configGeralService.js), não
  precisam mais viajar escondidos de formulário em formulário.
*/
const _exceto = typeof exceto !== 'undefined' ? exceto : [];
%>
<% if (!_exceto.includes('tecnologia')) { %>
  <% tecnologiasSelecionadas.forEach(tec => { %><input type="hidden" name="tecnologia" value="<%= tec %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('statusReparo')) { %>
  <% statusReparoSelecionados.forEach(v => { %><input type="hidden" name="statusReparo" value="<%= v %>" /><% }) %>
<% } %>
<% if (!_exceto.includes('statusReasonReparo')) { %>
  <% statusReasonReparoSelecionados.forEach(v => { %><input type="hidden" name="statusReasonReparo" value="<%= v %>" /><% }) %>
<% } %>
