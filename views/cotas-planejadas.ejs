<%- include('partials/head') %>

<%
  const tiposCotas = [
    { tipo: 'instalacao', label: 'Instalação' },
    { tipo: 'servico', label: 'Serviço' },
    { tipo: 'me', label: 'ME' },
    { tipo: 'reparo', label: 'Reparos' },
  ];
  const rotuloTipo = t => (tiposCotas.find(x => x.tipo === t) || {}).label || t;

  // Chaves de janela sem espaço (Excel usa "08:30-10:30", label do painel "08:30 - 10:30").
  const janelaKeys = janelasInstalacaoLabels.map(label => String(label).replace(/\s/g, ''));
  // Totais por janela (rodapé): Planejadas soma sempre; D0 só soma quem tem D0.
  const totaisPlanejadas = janelasInstalacaoLabels.map((_, j) =>
    linhasInstalacoes.reduce((acc, l) => acc + (l.minutos[j] || 0), 0)
  );
  const totaisD0 = janelaKeys.map(chave => {
    let soma = 0, tem = false;
    linhasInstalacoes.forEach(l => {
      const d0 = (mapaCotasD0[l.bucket] || {})[chave];
      if (d0 && d0.cotaAberta != null) { soma += Number(d0.cotaAberta); tem = true; }
    });
    return tem ? soma : null;
  });
%>

<section class="panel panel-slim">
  <div class="panel-header panel-header-row">
    <div>
      <h2 title="Cotas planejadas por bucket em cada janela de horário, comparadas com as cotas do dia (D0) do Elos">
        <svg class="title-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Cotas Planejadas
      </h2>
      <p class="hint">
        <strong>Cotas Planejadas</strong> = COTAS(min) de Instalações (mesmo cálculo da página principal);
        <strong>Status</strong> e <strong>COTAS D0</strong> vêm do Excel de cotas do Elos (Age = D0). Envie os arquivos no botão <strong>Upload de cotas</strong>.
      </p>
    </div>
    <div class="panel-header-actions">
      <button type="button" class="btn-secundario btn-com-icone" id="cotas-upload-open-btn" aria-haspopup="dialog" aria-controls="cotas-upload-modal" title="Enviar Analítico Disponibilidade e Consumo PB (um arquivo por tipo)">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M6 10l6-6 6 6"/><path d="M4 20h16"/></svg>
        Upload de cotas
      </button>
      <a href="<%= linkVoltar %>" class="icon-btn" title="Voltar para a página principal">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
    </div>
  </div>
</section>

<section class="panel" id="cotas-tabela">
  <div class="table-scroll">
    <table class="cotas-table cotas-table-compact">
      <colgroup>
        <col class="colw-aliada" />
        <col class="colw-bucket" />
        <% janelasInstalacaoLabels.forEach(() => { %>
          <col class="colw-num" /><col class="colw-num" /><col class="colw-num" /><col class="colw-num" />
        <% }) %>
      </colgroup>
      <thead>
        <tr>
          <th rowspan="2" title="Empresa aliada responsável pelo bucket">Aliada</th>
          <th rowspan="2" title="Agrupamento de ARDs (armários) mapeado em depara_bucket">Instalação</th>
          <% janelasInstalacaoLabels.forEach(label => { %>
            <th colspan="4" class="group-header col-divider" title="Janela de horário <%= label %>"><%= label %></th>
          <% }) %>
        </tr>
        <tr>
          <% janelasInstalacaoLabels.forEach(label => { %>
            <th class="num col-divider" title="Status da cota do dia (D0) no Elos — <%= label %>">Status</th>
            <th class="num" title="COTAS(min) de Instalação (ordens × tempo do bucket) — <%= label %>">Planej.</th>
            <th class="num" title="Cota Aberta do Elos na linha Age = D0 — <%= label %>">D0</th>
            <th class="num" title="A definir — <%= label %>">Consumo</th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% let aliadaAtual = null; %>
        <% linhasInstalacoes.forEach(linha => { %>
          <% const novaAliada = linha.aliada !== aliadaAtual; aliadaAtual = linha.aliada; %>
          <tr class="<%= novaAliada ? 'group-start' : '' %>">
            <td><span class="aliada-badge aliada-color-<%= aliadaCoresInstalacoes[linha.aliada] %>"><%= linha.aliada %></span></td>
            <td class="celula-truncada" title="<%= linha.bucket %>"><%= linha.bucket %></td>
            <% janelaKeys.forEach((chave, j) => { %>
              <% const d0 = (mapaCotasD0[linha.bucket] || {})[chave] || null; %>
              <td class="col-divider <%= d0 && d0.status === 'Fechado' ? 'status-fechado' : (d0 ? 'status-aberto' : '') %>"><%= d0 ? d0.status : '—' %></td>
              <td class="num"><%= linha.minutos[j] || 0 %></td>
              <td class="num"><%= d0 && d0.cotaAberta != null ? d0.cotaAberta : '—' %></td>
              <td class="num celula-napplicavel" title="A definir">—</td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2" title="Soma de todos os buckets">Total geral</td>
          <% janelasInstalacaoLabels.forEach((label, j) => { %>
            <td class="col-divider"></td>
            <td class="num"><%= totaisPlanejadas[j] %></td>
            <td class="num"><%= totaisD0[j] != null ? totaisD0[j] : '—' %></td>
            <td class="num celula-napplicavel">—</td>
          <% }) %>
        </tr>
      </tfoot>
    </table>
  </div>
</section>

<dialog id="cotas-upload-modal" class="config-modal" data-abrir-automatico="<%= cotasUpload ? 'true' : '' %>">
  <div class="modal-header">
    <h3 title="Envia os relatórios de cotas do Elos (Excel, aba Export) — um arquivo por tipo. Cada envio substitui todo o conteúdo daquele tipo.">Analítico Disponibilidade e Consumo PB</h3>
    <button type="button" class="icon-btn" id="cotas-upload-close-btn" aria-label="Fechar" title="Fechar">&times;</button>
  </div>

  <% if (cotasUpload === 'ok') { %>
    <p class="alert alert-ok" style="margin: 1rem 1.25rem 0;">Cotas de <strong><%= rotuloTipo(cotasUploadTipo) %></strong> importadas: <strong><%= cotasUploadLinhas %></strong> linhas.</p>
  <% } else if (cotasUpload === 'erro') { %>
    <p class="alert alert-erro" style="margin: 1rem 1.25rem 0;">Falha ao importar cotas<%= cotasUploadTipo ? ' de ' + rotuloTipo(cotasUploadTipo) : '' %>: <%= cotasUploadErro %></p>
  <% } %>

  <div class="upload-compact-grid">
    <% tiposCotas.forEach(({ tipo, label }) => { %>
      <form class="cota-upload-item" method="post" action="/cotas/upload/<%= tipo %>" enctype="multipart/form-data">
        <div class="cota-upload-head">
          <span class="cota-upload-tipo"><%= label %></span>
          <% if (datasCargaCotas[tipo]) { %>
            <span class="cota-upload-data" title="Última atualização de <%= label %>">atualizado <%= datasCargaCotas[tipo] %></span>
          <% } else { %>
            <span class="cota-upload-data cota-upload-nunca" title="Nunca enviado">nunca enviado</span>
          <% } %>
        </div>
        <div class="cota-upload-row">
          <input type="file" name="arquivo" accept=".xlsx" required aria-label="Arquivo de cotas de <%= label %>" />
          <button type="submit" title="Enviar e substituir as cotas de <%= label %>">Enviar</button>
        </div>
      </form>
    <% }) %>
  </div>
  <p class="hint" style="margin: 0 1.25rem 1.25rem;">Cada envio <strong>substitui</strong> todo o conteúdo daquele tipo. Por enquanto só as cotas de <strong>Instalação</strong> alimentam a tabela acima; os outros tipos ficam guardados para uso futuro.</p>
</dialog>

<%- include('partials/footer') %>
