<%- include('partials/head') %>

<%
  const tiposCotas = [
    { tipo: 'instalacao', label: 'Instalação' },
    { tipo: 'servico', label: 'Serviço' },
    { tipo: 'me', label: 'ME' },
    { tipo: 'reparo', label: 'Reparos' },
  ];
  const rotuloTipo = (t) => (tiposCotas.find(x => x.tipo === t) || {}).label || t;

  /*
    Uma entrada por seção; a tabela em si é o partial `tabela-cotas`. ME e Reparos
    entram aqui quando tiverem o recorte de Consumo definido (ver CONSUMO_POR_TIPO
    em cotasService.js) -- até lá seguem como abas desabilitadas.
  */
  const secoes = [
    {
      id: 'instalacao',
      label: 'Instalação',
      titulo: 'Cotas de Instalação em D0',
      rotuloColuna: 'Instalação',
      linhas: linhasInstalacoes,
      janelasLabels: janelasInstalacaoLabels,
      aliadaCores: aliadaCoresInstalacoes,
      mapaD0: mapaCotasD0,
      mapaConsumo: mapaConsumo,
      campoTempo: 'tempoInstalacaoMinutos',
    },
    {
      id: 'servico',
      label: 'Serviços',
      titulo: 'Cotas de Serviços em D0',
      rotuloColuna: 'Serviço',
      linhas: linhasServicos,
      janelasLabels: janelasServicoLabels,
      aliadaCores: aliadaCoresServicos,
      mapaD0: mapaCotasD0Servico,
      mapaConsumo: mapaConsumoServico,
      campoTempo: 'tempoServicoMinutos',
    },
  ];
  const abasFuturas = ['ME', 'Reparos'];
%>

<section class="panel" id="cotas-tabela">
  <div class="tabela-card-header">
    <div>
      <% secoes.forEach((secao, i) => { %>
        <div class="secao-cabecalho" data-secao="<%= secao.id %>" <%= i === 0 ? '' : 'hidden' %>>
          <h2 class="tabela-card-titulo"><%= secao.titulo %></h2>
          <p class="tabela-card-contexto">
            Cluster GOIANIA · <%= secao.linhas.length %> buckets · <%= secao.janelasLabels.length %> janelas
            <% if (datasCargaCotas[secao.id]) { %>
              · cotas do ETA de <strong><%= datasCargaCotas[secao.id] %></strong>
            <% } else { %>
              · <strong>cotas do ETA ainda não importadas</strong>
            <% } %>
          </p>
        </div>
      <% }) %>
    </div>
    <div class="tabela-card-acoes">
      <div class="unidade-toggle">
        <span class="unidade-toggle-label" id="rotulo-unidade">Ver em</span>
        <div class="secao-tabs" role="group" aria-labelledby="rotulo-unidade">
          <button type="button" class="secao-tab unidade-tab is-active" data-unidade="min" aria-pressed="true" title="Mostrar os valores em minutos">Minutos</button>
          <button type="button" class="secao-tab unidade-tab" data-unidade="qtd" aria-pressed="false" title="Mostrar os valores em quantidade de ordens">Ordens</button>
        </div>
      </div>
      <nav class="secao-tabs" aria-label="Seção">
        <% secoes.forEach((secao, i) => { %>
          <button type="button" class="secao-tab secao-aba <%= i === 0 ? 'is-active' : '' %>" data-secao="<%= secao.id %>" aria-pressed="<%= i === 0 ? 'true' : 'false' %>"><%= secao.label %></button>
        <% }) %>
        <% abasFuturas.forEach(label => { %>
          <button type="button" class="secao-tab" disabled title="Em breve"><%= label %></button>
        <% }) %>
      </nav>
    </div>
  </div>

  <% secoes.forEach((secao, i) => { %>
    <div class="secao-painel" data-secao="<%= secao.id %>" <%= i === 0 ? '' : 'hidden' %>>
      <%- include('partials/tabela-cotas', { secao: secao }) %>
    </div>
  <% }) %>

  <p class="tabela-nota">
    <strong>Planej.</strong> = COTAS da Sugestão (mesmo cálculo da página inicial) ·
    <strong>Status</strong> e <strong>D0</strong> = cota do dia no ETA (Age = D0) ·
    <strong>Consumo</strong> = ordens agendadas para hoje.
    Use <strong>Ver em</strong> para alternar entre minutos e quantidade de ordens — a conversão é sempre
    o tempo do bucket (<code>depara_tempo_bucket</code>): minutos ÷ tempo = ordens.
  </p>
</section>

<dialog id="cotas-upload-modal" class="config-modal" data-abrir-automatico="<%= cotasUpload ? 'true' : '' %>">
  <div class="modal-header">
    <h3 title="Envia os relatórios de cotas do ETA (Excel, aba Export) — um arquivo por tipo. Cada envio substitui todo o conteúdo daquele tipo.">Analítico Disponibilidade e Consumo PB</h3>
    <button type="button" class="icon-btn" id="cotas-upload-close-btn" aria-label="Fechar" title="Fechar">&times;</button>
  </div>

  <% if (cotasUpload === 'ok') { %>
    <p class="alert alert-ok" data-auto-dismiss style="margin: 1rem 1.25rem 0;">Cotas de <strong><%= rotuloTipo(cotasUploadTipo) %></strong> importadas: <strong><%= cotasUploadLinhas %></strong> linhas.</p>
  <% } else if (cotasUpload === 'erro') { %>
    <p class="alert alert-erro" data-auto-dismiss style="margin: 1rem 1.25rem 0;">Falha ao importar cotas<%= cotasUploadTipo ? ' de ' + rotuloTipo(cotasUploadTipo) : '' %>: <%= cotasUploadErro %></p>
  <% } %>

  <div class="upload-compact-grid">
    <% tiposCotas.forEach(({ tipo, label }) => { %>
      <form class="cota-upload-item" method="post" action="/cotas/upload/<%= tipo %>" enctype="multipart/form-data" data-loading="Enviando e processando o arquivo…">
        <div class="cota-upload-head">
          <span class="cota-upload-tipo"><%= label %></span>
          <% if (datasCargaCotas[tipo]) { %>
            <span class="cota-upload-data" title="Última atualização de <%= label %>">atualizado <%= datasCargaCotas[tipo] %></span>
          <% } else { %>
            <span class="cota-upload-data cota-upload-nunca" title="Nunca enviado">nunca enviado</span>
          <% } %>
        </div>
        <div class="cota-upload-row">
          <input type="file" name="arquivo" accept=".xlsx" required aria-label="Arquivo de cotas de <%= label %>" />
          <button type="submit" title="Enviar e substituir as cotas de <%= label %>">Enviar</button>
        </div>
      </form>
    <% }) %>
  </div>
  <p class="hint" style="margin: 0 1.25rem 1.25rem;">Cada envio <strong>substitui</strong> todo o conteúdo daquele tipo. Hoje <strong>Instalação</strong> e <strong>Serviço</strong> alimentam as tabelas acima; ME e Reparos ficam guardados para quando as abas entrarem.</p>
</dialog>

<%- include('partials/footer') %>
